        "新版爬塔_开始位置": {
            "type": "select",
            "label": "开始位置",
            "description": "设置在哪个界面开始任务",
            "default_case": "主页",
            "cases": [
                {
                    "name": "开始位置_主页",
                    "label": "主页",
                    "description": "从主页开始，不需要调整编队时选择"
                },
                {
                    "name": "开始位置_进入星塔后",
                    "label": "进入星塔后",
                    "description": "进入星塔后开始，需要调整编队时或爬塔中断时选择",
                    "pipeline_override": {
                        "星塔_跳过进入星塔流程_agent": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "新版爬塔_爬塔次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "爬塔次数",
                    "pipeline_type": "int",
                    "default": "1",
                    "verify": "^[1-9]\\d*$",
                    "pattern_msg": "请输入爬塔次数"
                }
            ],
            "pipeline_override": {
                "星塔_循环用节点_agent": {
                    "attach": {
                        "loop_count": "{爬塔次数}"
                    }
                }
            }
