{
    "option": {
        "新版爬塔_预设作业_cn": {
            "resource": [
                "官服"
            ],
            "type": "select",
            "label": "预设作业",
            "description": "选择预设作业，「无」表示只选择系统推荐潜能，「手动输入」可以自己输入作业名<br>预设作业可能会覆盖一些选项设置，开始任务时需要留意提示信息",
            "default_case": "无",
            "cases": [
                {
                    "name": "无",
                    "description": "只会选择系统推荐潜能"
                },
                {
                    "name": "手动输入文件名",
                    "description": "手动输入文件名，以使用自定义作业",
                    "option": [
                        "预设作业_手动输入作业名"
                    ]
                },
                {
                    "name": "小禾+苍蓝+多娜",
                    "pipeline_override": {
                        "星塔_入口_agent": {
                            "attach": {
                                "preset_name": "xiaohe_canglan_duona_cn.json"
                            }
                        }
                    }
                },
                {
                    "name": "千都世+多娜+特丽莎",
                    "pipeline_override": {
                        "星塔_入口_agent": {
                            "attach": {
                                "preset_name": "qiandushi_duona_telisha_cn.json"
                            }
                        }
                    }
                },
                {
                    "name": "小禾+新春科洛妮丝+格芮（土印记企鹅流）",
                    "pipeline_override": {
                        "星塔_入口_agent": {
                            "attach": {
                                "preset_name": "xiaohe_chunke_gerui_tuyinjiqie_cn.json"
                            }
                        }
                    }
                },
                {
                    "name": "小禾+新春科洛妮丝+岭川（枯萎流）",
                    "pipeline_override": {
                        "星塔_入口_agent": {
                            "attach": {
                                "preset_name": "xiaohe_chunke_lingchuan_kuwei_cn.json"
