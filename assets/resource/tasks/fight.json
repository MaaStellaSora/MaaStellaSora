        "选择悬赏试炼难度": {
            "type": "input",
            "inputs": [
                {
                    "name": "难度",
                    "pipeline_type": "string",
                    "default": "1",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入难度",
                    "description": "请输入难度"
                }
            ],
            "pipeline_override": {
                "战斗_选择难度": {
                    "recognition": {
                        "param": {
                            "expected": [
                                "(难度|難度|難易度|Difficulty){难度}(?!\\d)"
                            ]
                        }
                    },
                    "focus": {
                        "Node.Action.Succeeded": "选择难度_{难度}"
                    }
                }
            }
        },
        "悬赏试炼消耗所有干劲": {
            "type": "switch",
            "label": "消耗所有干劲",
            "description": "开启此项后，将无视输入的次数，直接消耗所有干劲",
            "default_case": "No",
            "cases": [
                {
                    "name": "No",
                    "option": [
                        "自定义快速作战次数"
                    ]
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "战斗_快速战斗": {
                            "next": [
                                "通用_消耗所有干劲"
                            ]
                        }
                    }
                }
