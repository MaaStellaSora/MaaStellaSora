{
    "task": [
        {
            "name": "新版爬塔",
            "entry": "星塔_入口_agent",
            "description": "新版爬塔目前仍在测试，如有问题请通过issue等渠道反馈",
            "option": [
                "新版爬塔_开始位置",
                "新版爬塔_爬塔次数",
                "新版爬塔_预设作业_cn",
                "新版爬塔_预设作业_tw",
                "新版爬塔_预设作业_en",
                "新版爬塔_预设作业_jp",
                "新版爬塔_属性塔",
                "新版爬塔_潜能最大刷新次数",
                "新版爬塔_商店_购买音符策略",
                "新版爬塔_商店_其他音符策略",
                "新版爬塔_商店_中途商店刷新最小金额",
                "新版爬塔_商店_潜能特饮折扣",
                "新版爬塔_商店_5个音符折扣",
                "新版爬塔_商店_15个音符折扣",
                "新版爬塔_商店_最大强化金额",
                "新版爬塔_商店_强化递增金额"
            ]
        }
    ],
    "option": {
        "新版爬塔_开始位置": {
            "type": "select",
            "label": "开始位置",
            "description": "设置在哪个界面开始任务",
            "default_case": "主页",
            "cases": [
                {
                    "name": "开始位置_主页",
                    "label": "主页",
                    "description": "从主页开始，不需要调整编队时选择"
                },
                {
                    "name": "开始位置_进入星塔后",
                    "label": "进入星塔后",
                    "description": "进入星塔后开始，需要调整编队时或爬塔中断时选择",
                    "pipeline_override": {
                        "星塔_跳过进入星塔流程_agent": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "新版爬塔_爬塔次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "爬塔次数",
                    "pipeline_type": "int",
                    "default": "1",
                    "verify": "^[1-9]\\d*$",
                    "pattern_msg": "请输入爬塔次数"
                }
            ],
            "pipeline_override": {
                "星塔_循环用节点_agent": {
                    "attach": {
                        "loop_count": "{爬塔次数}"
                    }
                }
            }
        },
        "新版爬塔_属性塔": {
            "type": "select",
            "label": "属性塔",
            "default_case": "属性_光土",
            "cases": [
                {
                    "name": "属性_光土",
                    "label": "光土",
                    "pipeline_override": {
                        "星塔_属性塔选择": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "ClimbTower_agent/爬塔_光土__387_137_124_45__337_87_224_145.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "属性_水风",
                    "label": "水风",
                    "pipeline_override": {
                        "星塔_属性塔选择": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "ClimbTower_agent/爬塔_水风__384_271_129_39__334_221_229_139.png"
                                    ]
                                }
                            }
                        }
                    }
                },
                {
                    "name": "属性_火暗",
                    "label": "火暗",
                    "pipeline_override": {
                        "星塔_属性塔选择": {
                            "recognition": {
                                "param": {
                                    "template": [
                                        "ClimbTower_agent/爬塔_火暗__381_404_129_39__331_354_229_139.png"
                                    ]
                                }
                            }
                        }
                    }
                }
            ]
        },
        "新版爬塔_潜能最大刷新次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "潜能最大刷新次数",
                    "pipeline_type": "int",
                    "default": "2",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入潜能最大刷新次数"
                }
            ],
            "pipeline_override": {
                "星塔_节点_选择潜能_agent": {
                    "attach": {
                        "max_refresh_count": "{潜能最大刷新次数}"
                    }
                }
            }
        },
        "新版爬塔_商店_购买音符策略": {
            "type": "select",
            "label": "购买音符策略",
            "default_case": "激活协奏",
            "cases": [
                {
                    "name": "无"
                },
                {
                    "name": "激活协奏",
                    "description": "只买与协奏有关的音符",
                    "pipeline_override": {
                        "星塔_节点_商店_购物_agent": {
                            "attach": {
                                "buy_assist_melody": true
                            }
                        }
                    }
                }
            ]
        },
        "新版爬塔_商店_其他音符策略": {
            "type": "checkbox",
            "label": "其他音符策略",
            "description": "这里勾选的会与上面的音符策略同时生效",
            "cases": [
