        "自定义快速作战次数": {
            "type": "input",
            "label": "自定义快速作战次数",
            "inputs": [
                {
                    "name": "次数",
                    "label": "次数",
                    "description": "打几次就填几",
                    "default": "1",
                    "pipeline_type": "int",
                    "verify": "^[1-9]\\d*$"
                }
            ],
            "pipeline_override": {
                "通用_换算快速作战次数": {
                    "action": {
                        "type": "Custom",
                        "param": {
                            "custom_action": "utool_calc_repeat",
                            "custom_action_param": "{次数}"
                        }
                    }
                }
            }
        },
        "邀约旅人": {
            "type": "input",
            "inputs": [
                {
                    "name": "1号",
                    "pipeline_type": "string",
                    "default": "希娅",
                    "description": "请输入旅人名字，如希娅。如没有邀约对象请留空"
                },
                {
                    "name": "2号",
                    "pipeline_type": "string",
                    "default": "",
                    "description": "请输入旅人名字，如希娅。如没有邀约对象请留空"
                },
                {
                    "name": "3号",
                    "pipeline_type": "string",
                    "default": "",
                    "description": "请输入旅人名字，如希娅。如没有邀约对象请留空"
                },
                {
                    "name": "4号",
                    "pipeline_type": "string",
                    "default": "",
                    "description": "请输入旅人名字，如希娅。如没有邀约对象请留空"
                },
                {
                    "name": "5号",
                    "pipeline_type": "string",
                    "default": "",
                    "description": "请输入旅人名字，如希娅。如没有邀约对象请留空"
                }
            ],
            "pipeline_override": {
                "邀约_1号": {
                    "recognition": {
                        "param": {
                            "expected": [
                                "{1号}"
                            ]
                        }
                    },
                    "focus": {
                        "Node.Recognition.Succeeded": "尝试邀约_{1号}"
                    }
                },
                "邀约_2号": {
                    "recognition": {
                        "param": {
                            "expected": [
                                "{2号}"
                            ]
                        }
                    },
                    "focus": {
                        "Node.Recognition.Succeeded": "尝试邀约_{2号}"
                    }
                },
                "邀约_3号": {
                    "recognition": {
                        "param": {
                            "expected": [
                                "{3号}"
                            ]
                        }
                    },
                    "focus": {
                        "Node.Recognition.Succeeded": "尝试邀约_{3号}"
                    }
                },
                "邀约_4号": {
                    "recognition": {
                        "param": {
                            "expected": [
                                "{4号}"
                            ]
                        }
                    },
                    "focus": {
                        "Node.Recognition.Succeeded": "尝试邀约_{4号}"
                    }
                },
                "邀约_5号": {
                    "recognition": {
                        "param": {
                            "expected": [
                                "{5号}"
                            ]
                        }
                    },
                    "focus": {
