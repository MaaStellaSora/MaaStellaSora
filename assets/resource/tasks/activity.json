{
    "task": [
        {
            "name": "活动快速战斗",
            "entry": "活动_入口",
            "description": "自动打开活动页面，并且对活动第一关进行快速战斗",
            "option": [
                "作战关卡",
                "活动战斗消耗所有干劲"
            ]
        }
    ],
    "option": {
        "作战关卡": {
            "type": "input",
            "inputs": [
                {
                    "name": "活动关卡名称",
                    "label": "关卡名称",
                    "description": "点击关卡出现问题时可以修改该选项，支持正则表达式。默认为「1-\\d+」（即1-数字）<br>罗马数字（如Ⅵ等）请用半角英文字母I、V、X代替",
                    "default": "1-\\d+",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "活动_选择活动关卡": {
                    "recognition": {
                        "param": {
                            "expected": [
                                "{活动关卡名称}"
                            ]
                        },
                        "type": "OCR"
                    }
                }
            }
        },
        "活动战斗消耗所有干劲": {
            "type": "switch",
            "label": "消耗所有干劲",
            "description": "开启此项后，将无视输入的次数，将直接消耗所有干劲",
            "default_case": "No",
            "cases": [
                {
                    "name": "No",
                    "option": [
                        "自定义快速作战次数"
                    ]
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "活动_开启快速战斗": {
                            "next": [
                                "通用_消耗所有干劲"
                            ]
                        }
                    }
                }
            ]
        }
    }
}
