  "星塔_节点_选择潜能_agent": {
    "recognition": {
      "type": "Custom",
      "param": {
        "custom_recognition": "choose_potential_recognition"
      }
    },
    "action": {
      "type": "DoNothing" // 因为设置为recognition方便debug，但实际操作不一定会点击，所以交给识别函数点击了
    },
    "next": [
      "星塔_节点_选择潜能_拿走_agent"
    ],
    "attach": {
      "priority_list": [],
      "max_refresh_count": 5,
      "reserved_coin": 0,
      // 触发潜能选择的类型↓，"default"表示升级或者选项触发，"drink"表示潜能特饮触发，"enhance"表示强化触发
      "trigger_type": "default",
      // 潜能处理方式↓，"default+"表示在推荐图标基础上还会根据其他信息筛选，"json"表示使用自定义优先级，否则仅靠推荐图标选择潜能
      "handler": "default+",
      "chooser": "tower_8",
      // 策略通用参数↓
      // tower_8_strategy代表塔8潜能选择严格程度，["conservative", "balanced", "greedy"]
      // tower_8_capacity_strategy代表塔8倾向于选新潜能还是升级旧潜能，["normal", "greedy"]
      "tower_8_strategy": "balanced",
      "tower_8_capacity_strategy": "normal"
    },
    "post_wait_freeze": 100,
    "timeout": 2000
  },
