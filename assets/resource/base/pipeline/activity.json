{
  "活动_入口": {
    "action": {
      "param": {},
      "type": "DoNothing"
    },
    "next": [
      "活动_判断是否在主页",
      {
        "jump_back": true,
        "name": "通用_返回主页"
      }
    ],
    "recognition": {
      "param": {},
      "type": "DirectHit"
    }
  },
  "活动_判断是否在主页": {
    "action": {
      "param": {},
      "type": "DoNothing"
    },
    "recognition": {
      "param": {
        "template": [
          "menu.png"
        ]
      },
      "type": "TemplateMatch"
    },
    "next": [
      "活动_打开活动"
    ]
  },
  "活动_开启快速战斗": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "next": [
      "通用_换算快速作战次数",
      "通用_返回主页"
    ],
    "recognition": {
      "param": {
        "expected": [
          "快速战斗"
        ]
      },
      "type": "OCR"
    },
    "post_wait_freezes": 100
  },
  "活动_开始战斗": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "focus": {
      "Node.Action.Starting": "点击开始战斗"
    },
    "next": [
      "活动_确认",
      {
        "jump_back": true,
        "name": "活动_关闭升级界面"
      }
    ],
    "recognition": {
      "param": {
        "expected": [
          "开始战斗"
        ]
      },
      "type": "OCR"
    }
  },
  "活动_关闭升级界面": {
    "action": {
      "param": {
        "target": [
          640,
          700
        ]
      },
      "type": "Click"
    },
    "focus": {
      "Node.Action.Starting": "正在关闭升级界面"
    },
    "recognition": {
      "param": {
        "roi": [
          187,
          302,
          578,
          132
        ],
        "expected": [
          "权限等级"
        ]
      },
      "type": "OCR"
    },
    "post_delay": 1000
  },
  "活动_打开活动": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "focus": {
      "Node.Action.Starting": "正在打开活动"
    },
    "next": [
      "活动_活动界面"
    ],
    "recognition": {
      "param": {
        "template": [
          "activity/banner.png"
        ]
      },
      "type": "TemplateMatch"
    }
  },
  "活动_战斗关卡按钮": {
    "recognition": {
      "param": {
        "expected": [
          "战斗关卡"
        ],
        "roi": [
          0,
          90,
          1280,
          630
        ]
      },
      "type": "OCR"
    },
    "next": [
      "活动_点击活动战斗关卡"
    ],
    "pre_delay": 0,
    "post_delay": 0
  },
  "活动_活动界面": {
    "recognition": {
      "param": {
        "all_of": [
          "活动_战斗关卡按钮"
        ]
      },
      "type": "And"
    },
    "next": [
      "活动_点击活动战斗关卡"
    ],
    "post_wait_freezes": {
      "time": 100,
      "timeout": 2000
    }
  },
  "活动_添加战斗次数": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "focus": {
      "Node.Recognition.Failed": "检测到没有通关活动关卡 继续下一步",
      "Node.Action.Starting": "正在添加战斗次数"
    },
    "next": [
      "活动_开始战斗"
    ],
    "on_error": [
      "通用_返回主页"
    ],
    "recognition": {
      "param": {
        "template": [
          "add.png"
        ]
      },
      "type": "TemplateMatch"
    },
    "repeat": 1,
    "repeat_delay": 1000
  },
  "活动_点击活动战斗关卡": {
    "action": {
      "type": "Click"
    },
    "next": [
      "活动_选择活动难度",
      "活动_点击活动战斗关卡"
    ],
    "recognition": {
      "param": {
        "all_of": [
          "活动_战斗关卡按钮"
        ]
      },
      "type": "And"
    },
    "post_wait_freezes": {
      "time": 100,
      "timeout": 1000
    }
  },
  "活动_选择活动难度": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "next": [
      "活动_选择活动关卡"
    ],
    "recognition": {
      "param": {
        "expected": [
          "普通"
        ]
      },
      "type": "OCR"
    },
    "post_wait_freezes": 100
  },
  "活动_确认": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "focus": {
      "Node.Action.Succeeded": "正在点击确认"
    },
    "next": [
      "通用_返回主页",
      {
        "jump_back": true,
        "name": "活动_关闭升级界面"
      }
    ],
    "recognition": {
      "param": {
        "expected": [
          "确认"
        ]
      },
      "type": "OCR"
    }
  },
  "活动_选择活动关卡": {
    "action": {
      "param": {},
      "type": "Click"
    },
    "next": [
      "活动_开启快速战斗"
    ],
    "recognition": {
      "param": {
        "expected": [
          "1-1"
        ],
        "replace": [
          [
            "Ⅰ",
            "I"
          ],
          [
            "Ⅱ",
            "II"
          ],
          [
            "Ⅲ",
            "III"
          ],
          [
            "Ⅳ",
            "IV"
          ],
          [
            "Ⅴ",
            "V"
          ],
          [
            "Ⅵ",
            "VI"
          ],
          [
            "Ⅶ",
            "VII"
          ],
          [
            "Ⅷ",
            "VIII"
          ]
        ],
        "threshold": 0.6
      },
      "type": "OCR"
    },
    "post_wait_freezes": 100
  }
}