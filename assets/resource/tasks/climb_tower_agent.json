                            "attach": {
                                "melody_of_stamina": true
                            }
                        }
                    }
                }
            ]
        },
        "新版爬塔_商店_中途商店刷新最小金额": {
            "type": "input",
            "inputs": [
                {
                    "name": "中途商店刷新最小金额",
                    "description": "只在中途商店生效。在最终商店会无视该金额，尽可能刷新。",
                    "pipeline_type": "int",
                    "default": "1500",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入中途商店刷新最小金额"
                }
            ],
            "pipeline_override": {
                "星塔_节点_商店_购物_agent": {
                    "attach": {
                        "regular_shop_refresh_threshold": "{中途商店刷新最小金额}"
                    }
                }
            }
        },
        "新版爬塔_商店_潜能特饮折扣": {
            "type": "select",
            "label": "潜能特饮折扣",
            "description": "买入不高于该折扣的潜能特饮，除非符合动态溢购情况或离开最终商店前",
            "default_case": "8折",
            "cases": [
                {
                    "name": "全价"
                },
                {
                    "name": "8折",
                    "pipeline_override": {
                        "星塔_节点_商店_购物_agent": {
                            "attach": {
                                "drink_discount_threshold": 0.8
                            }
                        }
                    },
                    "option": [
                        "新版爬塔_商店_动态溢购"
                    ]
                },
                {
                    "name": "5折",
                    "pipeline_override": {
                        "星塔_节点_商店_购物_agent": {
                            "attach": {
                                "drink_discount_threshold": 0.5
                            }
                        }
                    },
                    "option": [
                        "新版爬塔_商店_动态溢购"
                    ]
                }
            ]
        },
        "新版爬塔_商店_动态溢购": {
            "type": "input",
            "inputs": [
                {
                    "name": "动态溢购",
                    "description": "基于可刷新次数动态预留金币，并自动用溢出部分购买高价潜能特饮<br>如设置400，那么在可刷新次数为1时，会预留800金币<br>在最终商店时，仍会用光预留金币",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "400"
                }
            ],
            "pipeline_override": {
                "星塔_节点_商店_购物_agent": {
                    "attach": {
                        "full_price_buy_reserve_base": "{动态溢购}"
                    }
                }
            }
        },
        "新版爬塔_商店_5个音符折扣": {
            "type": "select",
            "label": "5个音符折扣",
            "description": "买入不高于该折扣的音符",
            "default_case": "全价",
            "cases": [
                {
                    "name": "全价"
                },
                {
                    "name": "8折",
                    "pipeline_override": {
                        "星塔_节点_商店_购物_agent": {
                            "attach": {
                                "melody_5_discount_threshold": 0.8
                            }
                        }
                    }
                },
                {
                    "name": "5折",
                    "pipeline_override": {
                        "星塔_节点_商店_购物_agent": {
                            "attach": {
                                "melody_5_discount_threshold": 0.5
                            }
                        }
                    }
                }
            ]
        },
        "新版爬塔_商店_15个音符折扣": {
            "type": "select",
            "label": "15个音符折扣",
            "description": "买入不高于该折扣的音符",
            "default_case": "5折",
            "cases": [
                {
                    "name": "全价"
                },
                {
                    "name": "8折",
                    "pipeline_override": {
                        "星塔_节点_商店_购物_agent": {
                            "attach": {
                                "melody_15_discount_threshold": 0.8
                            }
                        }
                    }
                },
                {
                    "name": "5折",
                    "pipeline_override": {
                        "星塔_节点_商店_购物_agent": {
                            "attach": {
                                "melody_15_discount_threshold": 0.5
                            }
                        }
                    }
                }
            ]
        },
        "新版爬塔_商店_最大强化金额": {
            "type": "input",
            "inputs": [
                {
                    "name": "最大强化金额",
                    "default": "180",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "description": "单次强化消耗金币没超过该金额时，才会进行强化"
                }
            ],
            "pipeline_override": {
                "星塔_节点_商店_强化_agent": {
                    "attach": {
                        "max_cost": "{最大强化金额}"
                    }
                }
            }
        },
        "新版爬塔_商店_初始强化金额": {
            "type": "input",
            "inputs": [
                {
                    "name": "初始强化金额",
                    "default": "60",
                    "pipeline_type": "int",
                    "verify": "^[1-9]\\d*$",
                    "description": "没点相关研究时，需要自己调整<br>免费强化不算在内"
                }
            ],
            "pipeline_override": {
                "星塔_节点_商店_强化_agent": {
                    "attach": {
                        "initial_cost": "{初始强化金额}"
                    }
                }
            }
        },
        "预设作业_手动输入作业名": {
            "type": "input",
            "inputs": [
                {
                    "name": "预设作业_作业文件名",
                    "label": "作业文件名",
                    "pipeline_type": "string",
                    "description": "作业需以json格式保存在程序的/agent/presets/目录下，填写文件名时可以不添加.json后缀<br>自行编写作业可以使用更多隐藏功能"
                }
            ],
            "pipeline_override": {
                "星塔_入口_agent": {
                    "attach": {
                        "preset_name": "{预设作业_作业文件名}"
                    }
                }
            }
        }
    }
}