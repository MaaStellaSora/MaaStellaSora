{
    "interface_version": 2,
    "name": "MaaStellaSora",
    "description": "星塔助手（MaaStellaSora）提供对于游戏《星塔旅人》的自动签到、清理日常等功能，由 MaaFramework 强力驱动",
    "contact": "QQ交流群：1063132902  密码：星塔旅人",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaStellaSora",
    "github": "https://github.com/MaaStellaSora/MaaStellaSora",
    "version": "0.9.2",
    "custom_title": "星塔助手",
    "mirrorchyan_rid": "SSAH",
    "mirrorchyan_multiplatform": true,
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ],
        "timeout": -1
    },
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "xtlr|StellaSora",
                "screencap": "FramePool",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "SendMessageWithCursorPos"
            }
        },
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        },
        {
            "name": "PlayCover",
            "type": "PlayCover",
            "playcover": {
                "uuid": "maa.playcover"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "{PROJECT_DIR}/resource/base"
            ]
        },
        {
            "name": "台服",
            "path": [
                "{PROJECT_DIR}/resource/base",
                "{PROJECT_DIR}/resource/tw"
            ]
        },
        {
            "name": "国际服",
            "path": [
                "{PROJECT_DIR}/resource/base",
                "{PROJECT_DIR}/resource/en"
            ]
        },
        {
            "name": "日服",
            "path": [
                "{PROJECT_DIR}/resource/base",
                "{PROJECT_DIR}/resource/jp"
            ]
        }
    ],
    "task": [
        {
            "name": "登录游戏",
            "entry": "登录_登录",
            "description": "自动登录游戏，并且关闭活动弹窗以及签到弹窗"
        },
        {
            "name": "领取每日奖励",
            "entry": "采购_入口",
            "description": "自动领取采购中的每日奖励"
        },
        {
            "name": "心链送礼",
            "entry": "心链_入口",
            "description": "自动打开心链页面，并且为心链顶置旅人赠送礼物"
        },
        {
            "name": "邀约",
            "entry": "邀约_入口",
            "description": "自动邀约<br>由于选项过多，可能需要下拉菜单才能看到其他选项",
            "option": [
                "邀约旅人",
                "邀约旅人_1号_送礼",
                "邀约旅人_2号_送礼",
                "邀约旅人_3号_送礼",
                "邀约旅人_4号_送礼",
                "邀约旅人_5号_送礼"
            ]
        },
        {
            "name": "活动快速战斗",
            "entry": "活动_入口",
            "description": "自动打开活动页面，并且对活动第一关进行快速战斗",
            "option": [
                "作战关卡",
                "活动战斗消耗所有干劲"
            ]
        },
        {
            "name": "悬赏试炼快速战斗",
            "entry": "战斗_入口",
            "description": "自动前往悬赏试炼页面，并且对指定关卡进行快速战斗",
            "option": [
                "悬赏试炼关卡",
                "选择悬赏试炼难度",
                "悬赏试炼消耗所有干劲"
            ]
        },
        {
            "name": "领取并重新派遣委托",
            "entry": "委托_入口",
            "description": "自动领取并重新派遣委托"
        },
        {
            "name": "领取与赠送干劲",
            "entry": "好友_入口",
            "description": "自动前往好友页面，并且领取与赠送好友干劲"
        },
        {
            "name": "领取任务奖励",
            "entry": "任务_入口",
            "description": "自动前往任务页面，并且领取任务奖励"
        },
        {
            "name": "领取邮箱奖励",
            "entry": "邮箱_入口",
            "description": "自动打开邮箱页面，并且领取邮箱奖励"
        },
        {
            "name": "领取基金奖励",
            "entry": "基金_入口",
            "description": "自动打开基金页面，并且领取基金奖励"
        }
    ],
    "import": [
        "resource/tasks/climb_tower_agent.json",
        "resource/tasks/climb_tower_presets.json"
    ],
